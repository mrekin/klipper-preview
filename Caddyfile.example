# Caddy configuration example for Klipper Print Share
# Replace example.com with your domain and adjust paths/ports as needed

example.com {
	# Allowed paths for Klipper Print Share
	@allowedKlipper {
		path_regexp ^/klipper/(view|_app|api/(status|gcode|token|config/base-path|thumbnail))
	}

	handle @allowedKlipper {
		uri strip_prefix /klipper
		reverse_proxy http://192.168.1.115:3030 {
			header_up X-Base-Path /klipper
		}
	}

	# Optional: redirect root to klipper path
	handle / {
		redir /klipper/view
	}
}

# Notes:
# - Replace example.com with your actual domain
# - Adjust the reverse_proxy URL (192.168.1.115:3030) to match your app's address
# - The X-Base-Path header tells the app it's running under /klipper prefix
# - thumbnail endpoint is required for model preview images on view page
